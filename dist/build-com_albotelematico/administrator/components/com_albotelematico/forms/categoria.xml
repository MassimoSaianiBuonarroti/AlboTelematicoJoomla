<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" label="Categoria">
        <field
            name="id"
            type="hidden"
        />

        <field
            name="title"
            type="text"
            label="Nome categoria"
            required="true"
        />

        <field
            name="ordering"
            type="number"
            label="Ordine"
            default="0"
        />

        <field
            name="state"
            type="list"
            label="Stato"
            default="1">
            <option value="1">Pubblicata</option>
            <option value="0">Non pubblicata</option>
        </field>
    </fieldset>
</form>
