<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" label="Dati atto">
        <field
            name="id"
            type="hidden"
        />

        <field
            name="title"
            type="text"
            label="Nome atto"
            required="true"
        />

        <field
            name="document_number"
            type="text"
            label="Numero documento"
            required="true"
        />

        <field
            name="albo_number"
            type="text"
            label="Numero albo pretorio"
            readonly="true"
        />

        <field
            name="document_date"
            type="calendar"
            label="Data documento"
            required="true"
            format="%Y-%m-%d"
        />

        <field
            name="publish_start"
            type="calendar"
            label="Inizio pubblicazione"
            required="true"
            format="%Y-%m-%d"
        />

        <field
            name="publish_end"
            type="calendar"
            label="Fine pubblicazione"
            required="true"
            format="%Y-%m-%d"
        />

        <field
            name="category"
            type="sql"
            label="Categoria"
            query="SELECT id AS value, title AS text FROM #__albo_categorie WHERE state = 1 ORDER BY ordering, title"
            key_field="value"
            value_field="text"
            required="false"
        />

        <field
            name="file"
            type="file"
            label="Allegati PDF (max 10)"
            description="Puoi aggiungere un file PDF alla volta"
            accept="application/pdf,.pdf"
        />


        <field
            name="state"
            type="list"
            label="Stato"
            default="1">
            <option value="1">Pubblicato</option>
            <option value="0">Non pubblicato</option>
        </field>
    </fieldset>
</form>
