<?xml version="1.0" encoding="utf-8"?>
<extension type="component" method="upgrade" version="5.0">
    <name>com_albotelematico</name>
    <author>Il tuo nome</author>
    <creationDate>2025-12-01</creationDate>
    <version>1.0.0</version>
    <description>Componente per la gestione dell'albo telematico</description>
    <namespace path="src">AlboTelematico\Component\Albotelematico</namespace>

    <administration>
        <menu link="index.php?option=com_albotelematico">
            Albo telematico
        </menu>

        <files folder=".">
            <filename>albotelematico.php</filename>
            <filename>config.xml</filename>
            <folder>services</folder>
            <folder>src</folder>
            <folder>sql</folder>
            <folder>language</folder>
            <folder>tmpl</folder>
            <folder>forms</folder>
        </files>

        <languages folder="language">
            <language tag="it-IT">it-IT/it-IT.com_albotelematico.ini</language>
            <language tag="it-IT">it-IT/it-IT.com_albotelematico.sys.ini</language>
        </languages>

        <!-- Script SQL installazione -->
        <install>
            <sql>
                <file driver="mysqli" charset="utf8mb4">sql/install.mysql.utf8.sql</file>
            </sql>
        </install>

        <update>
            <schemas>
                <schemapath type="mysql">sql/updates</schemapath>
            </schemas>
        </update>

    </administration>
</extension>
